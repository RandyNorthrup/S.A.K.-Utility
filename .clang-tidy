# =============================================================================
# S.A.K. Utility — Clang-Tidy Configuration
# Production-grade static analysis for C++23 / Qt 6 / MSVC 2022
# Requires: clang-tidy 17+
# =============================================================================
---
# Inherit sensible defaults, then override
InheritParentConfig: false

# Header filter: only analyze our own headers, not Qt/system
HeaderFilterRegex: 'include/sak/.*\.h$'

# Warnings are errors in CI — enforce zero tolerance
WarningsAsErrors: '*'

# Treat system headers as system (suppress diagnostics)
SystemHeaders: false

FormatStyle: file

Checks: >
  -*,

  # ── bugprone: catch common programming mistakes ────────────────────
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,

  # ── cert: CERT C++ secure coding rules ─────────────────────────────
  cert-*,
  -cert-err58-cpp,

  # ── clang-analyzer: deep static analysis ───────────────────────────
  clang-analyzer-*,

  # ── concurrency: thread-safety checks ──────────────────────────────
  concurrency-*,

  # ── cppcoreguidelines: C++ Core Guidelines ─────────────────────────
  cppcoreguidelines-*,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-constant-array-index,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -cppcoreguidelines-pro-type-union-access,
  -cppcoreguidelines-owning-memory,
  -cppcoreguidelines-non-private-member-variables-in-classes,
  -cppcoreguidelines-avoid-non-const-global-variables,

  # ── google: Google style subset ────────────────────────────────────
  google-*,
  -google-readability-todo,
  -google-build-using-namespace,

  # ── hicpp: High Integrity C++ ──────────────────────────────────────
  hicpp-*,
  -hicpp-signed-bitwise,
  -hicpp-no-array-decay,

  # ── misc: miscellaneous checks ─────────────────────────────────────
  misc-*,
  -misc-non-private-member-variables-in-classes,
  -misc-no-recursion,
  -misc-include-cleaner,

  # ── modernize: use modern C++ idioms ───────────────────────────────
  modernize-*,
  -modernize-use-trailing-return-type,
  -modernize-avoid-c-arrays,

  # ── performance: avoid unnecessary copies/allocations ──────────────
  performance-*,

  # ── portability ────────────────────────────────────────────────────
  portability-*,

  # ── readability: code clarity and consistency ──────────────────────
  readability-*,
  -readability-magic-numbers,
  -readability-function-cognitive-complexity,
  -readability-identifier-length,
  -readability-else-after-return,
  -readability-uppercase-literal-suffix,
  -readability-convert-member-functions-to-static,

CheckOptions:
  # ── Naming conventions (match existing codebase style) ─────────────
  # Classes: PascalCase
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase

  # Enums: PascalCase
  - key: readability-identifier-naming.EnumCase
    value: CamelCase
  - key: readability-identifier-naming.EnumConstantCase
    value: CamelCase

  # Functions: camelCase
  - key: readability-identifier-naming.FunctionCase
    value: camelBack
  - key: readability-identifier-naming.MethodCase
    value: camelBack

  # Members: m_ prefix + snake_case (match existing codebase)
  - key: readability-identifier-naming.MemberPrefix
    value: 'm_'
  - key: readability-identifier-naming.MemberCase
    value: lower_case

  # Constants: k prefix + CamelCase
  - key: readability-identifier-naming.ConstantCase
    value: CamelCase
  - key: readability-identifier-naming.ConstantPrefix
    value: 'k'
  - key: readability-identifier-naming.ConstexprVariableCase
    value: CamelCase
  - key: readability-identifier-naming.ConstexprVariablePrefix
    value: 'k'
  - key: readability-identifier-naming.StaticConstantCase
    value: CamelCase
  - key: readability-identifier-naming.StaticConstantPrefix
    value: 'k'

  # Global constants (also k prefix)
  - key: readability-identifier-naming.GlobalConstantCase
    value: CamelCase
  - key: readability-identifier-naming.GlobalConstantPrefix
    value: 'k'

  # Namespaces: lower_case
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case

  # Variables: snake_case
  - key: readability-identifier-naming.VariableCase
    value: lower_case
  - key: readability-identifier-naming.LocalVariableCase
    value: lower_case
  - key: readability-identifier-naming.ParameterCase
    value: lower_case

  # Template parameters: PascalCase
  - key: readability-identifier-naming.TemplateParameterCase
    value: CamelCase
  - key: readability-identifier-naming.TypeTemplateParameterCase
    value: CamelCase

  # Type aliases: PascalCase
  - key: readability-identifier-naming.TypeAliasCase
    value: CamelCase
  - key: readability-identifier-naming.TypedefCase
    value: CamelCase

  # Macros: UPPER_CASE
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE

  # ── Thresholds & limits ────────────────────────────────────────────
  - key: readability-function-size.LineThreshold
    value: '120'
  - key: readability-function-size.StatementThreshold
    value: '80'
  - key: readability-function-size.BranchThreshold
    value: '20'
  - key: readability-function-size.ParameterThreshold
    value: '8'
  - key: readability-function-size.NestingThreshold
    value: '5'

  # ── Modernize preferences ─────────────────────────────────────────
  - key: modernize-use-nullptr.NullMacros
    value: 'NULL'
  - key: modernize-use-auto.MinTypeNameLength
    value: '5'
  - key: modernize-loop-convert.MinConfidence
    value: 'reasonable'
  - key: modernize-pass-by-value.IncludeStyle
    value: 'google'
  - key: modernize-use-override.AllowOverrideAndFinal
    value: 'false'
  - key: modernize-use-emplace.ContainersWithPushBack
    value: '::std::vector;::std::list;::std::deque'
  - key: modernize-use-emplace.SmartPointers
    value: '::std::shared_ptr;::std::unique_ptr;::std::auto_ptr;::std::weak_ptr'

  # ── Performance tuning ────────────────────────────────────────────
  - key: performance-unnecessary-value-param.AllowedTypes
    value: 'QString;QStringList;QVariant;QUrl;QByteArray'
  - key: performance-for-range-copy.WarnOnAllAutoCopies
    value: 'true'
  - key: performance-move-const-arg.CheckTriviallyCopyableMove
    value: 'false'

  # ── Concurrency ───────────────────────────────────────────────────
  - key: concurrency-mt-unsafe.FunctionSet
    value: 'posix'

  # ── Miscellaneous ─────────────────────────────────────────────────
  - key: misc-unused-parameters.StrictMode
    value: 'false'
  - key: bugprone-argument-comment.StrictMode
    value: 'false'
  - key: bugprone-assert-side-effect.AssertMacros
    value: 'Q_ASSERT;Q_ASSERT_X'
  - key: bugprone-dangling-handle.HandleClasses
    value: 'std::string_view;std::span;QStringView'
  - key: bugprone-string-constructor.WarnOnLargeLength
    value: 'true'
  - key: bugprone-string-constructor.LargeLengthThreshold
    value: '8388608'
  - key: cppcoreguidelines-special-member-functions.AllowSoleDefaultDtor
    value: 'true'
  - key: cppcoreguidelines-special-member-functions.AllowMissingMoveFunctions
    value: 'true'
  - key: google-runtime-int.SignedTypePrefix
    value: 'int'
  - key: google-runtime-int.UnsignedTypePrefix
    value: 'uint'
  - key: google-runtime-int.TypeSuffix
    value: ''
  - key: hicpp-multiway-paths-covered.WarnOnMissingElse
    value: 'false'
...
