+
+static void windows_copy_raw_device_path(char *dest, size_t dest_size,
+					 const char *src)
+{
+	size_t i;
+
+	if (!dest_size)
+		return;
+	strncpy(dest, src, dest_size - 1);
+	dest[dest_size - 1] = 0;
+	if (!strncmp(src, "//./", 4) || !strncmp(src, "//?/", 4)) {
+		for (i = 0; dest[i]; i++)
