+
+	if (DeviceIoControl(handle, IOCTL_DISK_GET_DRIVE_GEOMETRY_EX,
+			    NULL, 0, &geometry, sizeof(geometry),
+			    &retbytes, NULL)) {
+		*size = geometry.DiskSize;
+		return 1;
+	}
+
+	return 0;
+}
